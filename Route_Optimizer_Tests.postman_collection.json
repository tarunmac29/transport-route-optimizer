    {
      "name": "Optimization Tests",
      "item": [
        {
          "name": "Distance Optimization - Central to Shopping",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/routes/optimize?from=1&to=5&type=distance",
              "host": ["{{baseUrl}}"],
              "path": ["routes", "optimize"],
              "query": [
                {"key": "from", "value": "1"},
                {"key": "to", "value": "5"},
                {"key": "type", "value": "distance"}
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has correct optimization type', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.optimizationType).to.eql('distance');",
                  "});",
                  "",
                  "pm.test('Route is reachable', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.reachable).to.be.true;",
                  "});",
                  "",
                  "pm.test('Path is not empty', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.path).to.be.an('array').that.is.not.empty;",
                  "});"
                ]
              }
            }
          ]
        },
